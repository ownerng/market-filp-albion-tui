    "outDir": "dist",
    "rootDir": "src",
    "declaration": false,
    "sourceMap": true,
    "module": "ESNext",
    "moduleResolution": "Bundler"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests", "scripts"]
}
